# ─── Copy this file to .env and fill in your values ───

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://gatka_app:Dexter2107@localhost:5432/gatka_site

# JWT secret key — generate a strong random string:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING_DO_NOT_USE_THIS_IN_PRODUCTION

# Token algorithm (keep as HS256)
ALGORITHM=HS256

# Token expiry in minutes (480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Directory where player photos and Aadhar scans are stored
UPLOAD_DIR=uploads
